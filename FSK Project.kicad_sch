	)
	(text "Shmitt trigger\nOn BB center was around equal between\n+45 and -45 deg\n2.4-2.6v\ncenter is best\n50k/100k about 20% up down"
		(exclude_from_sim no)
		(at 241.3 135.382 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "b5812c35-94ed-4628-abcc-c72cba4abb0d")
	)
	(text "> 1/2pi * 30kohm * 440pF\n\n  (1 / (2 × pi)) × (30 kiloohms) × (440\n  picofarads) ≈\n  2.100845249 μs\n\n> 1/ans\n\n  1 / ans ≈ 475.9988869 kHz\n\n475 is more than the 2x PC 2 output from 150kHz"
		(exclude_from_sim no)
		(at 288.036 75.946 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
